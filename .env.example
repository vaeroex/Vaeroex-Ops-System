NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI remains active unless this is explicitly changed to nvidia.
AI_PROVIDER=openai
NVIDIA_API_KEY=
# Optional path-specific model overrides. Leave blank until benchmark results justify a change.
VAEROEX_FOCUSED_EXPLANATION_MODEL=
VAEROEX_CROSS_BUSINESS_MODEL=
VAEROEX_FILE_ANALYSIS_MODEL=
# Optional evidence retrieval/cost controls.
VAEROEX_MAX_EVIDENCE_CHUNKS=8
OPENAI_INPUT_COST_CENTS_PER_1M=
OPENAI_OUTPUT_COST_CENTS_PER_1M=
NVIDIA_INPUT_COST_CENTS_PER_1M=
NVIDIA_OUTPUT_COST_CENTS_PER_1M=
# Optional provider safeguards. Defaults are production-safe when left blank.
VAEROEX_AI_RATE_LIMIT_WINDOW_SECONDS=600
VAEROEX_AI_USER_RATE_LIMIT=60
VAEROEX_AI_WORKSPACE_RATE_LIMIT=240
VAEROEX_WORKSPACE_MONTHLY_TOKEN_BUDGET=2000000
VAEROEX_SINGLE_REQUEST_TOKEN_BUDGET=120000
VAEROEX_OPENAI_TIMEOUT_MS=18000
VAEROEX_NVIDIA_TIMEOUT_MS=18000
# Admin-only provider smoke endpoint remains disabled unless explicitly enabled.
VAEROEX_AI_SMOKE_TEST_ENABLED=false
CRON_SECRET=
RESEND_API_KEY=
# Optional. Defaults to Vaeroex <hq@vaeroex.com>.
RESEND_FROM_EMAIL=
NEXT_PUBLIC_APP_URL=
VAEROEX_ADMIN_EMAILS=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_OPERATIONS_INTELLIGENCE_MONTHLY=

# Legacy Squarespace support only. Not required for new Stripe checkout.
SQUARESPACE_API_KEY=
SQUARESPACE_WEBHOOK_SECRET=
SQUARESPACE_VAEROEX_PRODUCT_ID=
SQUARESPACE_VAEROEX_SKU=
NEXT_PUBLIC_SQUARESPACE_VAEROEX_CHECKOUT_URL=
